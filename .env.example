# ============================================================================
# Concept frontend — environment configuration
#
# Copy this file to ".env" in the project root and adjust if needed.
# Vite only exposes variables prefixed with VITE_ to the browser — never put
# secrets here, only the backend's public URL and OAuth client ID.
# ============================================================================

# Where the Concept backend (see /server) is running.
VITE_API_BASE_URL=http://localhost:8787

# Optional: your GitHub OAuth App's Client ID (public, safe to expose).
# Only needed if you want the frontend to build the GitHub authorize URL
# itself; by default it asks the backend for this via /auth/github/login-url,
# which is simpler because the client ID then only has to be set in one place.
# VITE_GITHUB_CLIENT_ID=REPLACE_WITH_YOUR_GITHUB_CLIENT_ID
