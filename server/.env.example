# ============================================================================
# Concept backend — environment configuration
#
# Copy this file to ".env" in the same folder and fill in the real values.
# NEVER commit the real ".env" file — it's already in .gitignore.
# ============================================================================

# ---- GitHub OAuth App credentials -----------------------------------------
# Create an OAuth App at https://github.com/settings/developers
#   Homepage URL:            http://localhost:5173  (or your deployed frontend URL)
#   Authorization callback:  http://localhost:8787/auth/github/callback
#
# >>> REPLACE THESE TWO WITH YOUR REAL KEYS WHEN YOU HAVE THEM <<<
GITHUB_CLIENT_ID=REPLACE_WITH_YOUR_GITHUB_CLIENT_ID
GITHUB_CLIENT_SECRET=REPLACE_WITH_YOUR_GITHUB_CLIENT_SECRET

# ---- Concept Apps Repository ----------------------------------------------
# The GitHub repo that acts as the community apps backend (owner/repo).
# The server pushes to and reads from /apps/{slug} in this repo.
GITHUB_APPS_REPO_OWNER=concept-community
GITHUB_APPS_REPO_NAME=apps

# A personal access token (classic, with "repo" scope) OR a GitHub App
# installation token belonging to GITHUB_APPS_REPO_OWNER. Used for
# server-to-server calls (browsing/starring apps) that shouldn't require
# every visitor to sign in. Leave blank to only support signed-in pushes.
GITHUB_APPS_REPO_TOKEN=REPLACE_WITH_A_REPO_SCOPED_TOKEN

# ---- Session / server config -----------------------------------------------
SESSION_SECRET=REPLACE_WITH_A_LONG_RANDOM_STRING
PORT=8787

# Comma-separated list of origins allowed to call this API (your frontend URL).
CORS_ORIGIN=http://localhost:5173
